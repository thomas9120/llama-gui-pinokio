+def get_ui_asset_version():
+    git_res = run_git(["rev-parse", "--short=12", "HEAD"])
+    if git_res.returncode == 0 and git_res.stdout.strip():
+        return git_res.stdout.strip()
+
+    latest_mtime = 0
+    for rel_path in (
+        "ui/index.html",
+        "ui/css/tokens.css",
+        "ui/css/style.css",
+        "ui/js/flags.js",
+        "ui/js/manager.js",
+        "ui/js/presets.js",
+        "ui/js/app.js",
+    ):
+        path = BASE_DIR / rel_path
+        try:
+            latest_mtime = max(latest_mtime, int(path.stat().st_mtime))
+        except OSError:
+            pass
+    return str(latest_mtime or int(time.time()))
+
+
+def version_ui_asset_urls(html):
+    version = get_ui_asset_version()
+
+    def _replace(match):
+        attr = match.group(1)
+        asset_path = match.group(2).split("?", 1)[0]
+        return f'{attr}="{asset_path}?v={version}"'
+
+    return re.sub(r'(href|src)="(/(?:css|js)/[^"?#]+(?:\?[^"#]*)?)"', _replace, html)
+
